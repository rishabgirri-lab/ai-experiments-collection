# Copy this file to ".env" and fill in your values.
# The project auto-loads .env via python-dotenv (see main.py).

# ---- Required ----
# Your API key. The variable is named GROK_API_KEY for historical reasons but
# works with any OpenAI-compatible provider. If your key starts with "gsk-"
# it is a Groq key (groq.com), not xAI's Grok. Use the Groq settings below.
GROK_API_KEY=gsk-your-key-here

# ---- LLM endpoint ----
# Groq (key starts with gsk-)   -> https://api.groq.com/openai/v1
#   models e.g. llama-3.3-70b-versatile, llama-3.1-8b-instant,
#               openai/gpt-oss-120b, openai/gpt-oss-20b
# xAI Grok (key starts with xai-) -> https://api.x.ai/v1
#   models e.g. grok-2-latest
GROK_BASE_URL=https://api.groq.com/openai/v1
GROK_MODEL=llama-3.3-70b-versatile

# ---- Optional ----
# Set to "true" to enable CrewAI memory (may trigger embedding API calls).
ENABLE_MEMORY=false
