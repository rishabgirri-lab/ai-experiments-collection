# =====================================================================
# Copy this file to ".env" and fill in your real key:
#     cp .env.example .env
# =====================================================================

# Your GROQ API key (NOT an xAI/Grok key!). Get it from:
#     https://console.groq.com
# Groq keys start with "gsk_". They are a different product from xAI's
# "Grok" (whose keys start with "xai-"). This project uses GROQ.
GROQ_API_KEY=gsk-your-key-here

# Main model (capable, general purpose).
GROQ_MODEL=llama-3.3-70b-versatile

# Fast/cheap model used for high-volume nodes (classifiers, summaries).
# Examples select it with get_llm(model="fast").
GROQ_FAST_MODEL=llama-3.1-8b-instant

# Temperature applied to every model unless a node overrides it.
GROQ_TEMPERATURE=0

# Logging verbosity: DEBUG | INFO | WARNING. INFO shows node-by-node logs.
LOG_LEVEL=INFO

# ---------------------------------------------------------------------
# Optional LangSmith tracing. Leave blank to disable.
# ---------------------------------------------------------------------
# LANGSMITH_TRACING=true
# LANGSMITH_API_KEY=ls-your-key-here
# LANGSMITH_PROJECT=langgraph-groq
