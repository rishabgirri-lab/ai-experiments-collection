# Provide ONE provider key (or none -> deterministic SIMULATED mode).
# The repo auto-detects which provider to use.

# --- Option A: Groq (gsk_... keys; fast, free tier, open models) ---
GROQ_API_KEY=gsk_your-key-here

# --- Option B: OpenAI (sk-... keys) ---
# OPENAI_API_KEY=sk-your-key-here

# Optional overrides:
# OAI_MODEL=llama-3.3-70b-versatile   # Groq default; for OpenAI use e.g. gpt-4o-mini
# TOPIC=the benefits and risks of multi-agent AI systems for startups

# Note: a key starting with gsk_ is GROQ (GroqCloud). A "Grok" (xAI) key
# starts with xai- and uses base_url https://api.x.ai/v1 instead.
