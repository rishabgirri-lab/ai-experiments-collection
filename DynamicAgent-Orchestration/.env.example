# Copy this file to .env and fill in. .env is in .gitignore so it won't be committed.

# Which provider to use: anthropic, openai, or mock

# for mock running in test mode without making real API calls
# LLM_PROVIDER=mock

# OPENAI_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxx
# OPENAI_BASE_URL=https://api.groq.com/openai/v1
# OPENAI_MODEL=llama-3.3-70b-versatile

# Actual API calls to Groq's OpenAI-compatible API
set LLM_PROVIDER=openai
set OPENAI_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxx
set OPENAI_BASE_URL=https://api.groq.com/openai/v1
set OPENAI_MODEL=llama-3.3-70b-versatile


# Anthropic (https://console.anthropic.com/)
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-5

# OpenAI (https://platform.openai.com/api-keys)
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# OpenAI-compatible providers (Groq, OpenRouter, Together, Ollama).
# Set OPENAI_BASE_URL and use LLM_PROVIDER=openai with that provider's API key.
# Examples:
#   Groq:       OPENAI_BASE_URL=https://api.groq.com/openai/v1
#   OpenRouter: OPENAI_BASE_URL=https://openrouter.ai/api/v1
#   Together:   OPENAI_BASE_URL=https://api.together.xyz/v1
#   Ollama:     OPENAI_BASE_URL=http://localhost:11434/v1   (any string works as API key)

# Generation parameters
MAX_TOKENS=1024
TEMPERATURE=0.7

# Orchestration parameters
MAX_PARALLEL_AGENTS=4
REQUEST_TIMEOUT=60

# Logging
LOG_LEVEL=INFO
