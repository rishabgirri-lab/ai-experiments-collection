# ---------------------------------------------------------------------------
# Copy this file to ".env" and fill in your key:   cp .env.example .env
# Then load it into your shell before running examples:
#   macOS/Linux:  export $(grep -v '^#' .env | xargs)
#   Windows PS :  Get-Content .env | Where-Object {$_ -notmatch '^#'} | ForEach-Object { $p=$_.Split('=',2); [Environment]::SetEnvironmentVariable($p[0],$p[1]) }
# ---------------------------------------------------------------------------

# REQUIRED. Get a free key at https://console.groq.com/keys  (starts with gsk_)
GROQ_API_KEY=gsk_your_key_here

# OPTIONAL. A current Groq production model that supports tool/function calling.
# Groq rotates models; if you get a "model decommissioned" error, pick another
# from https://console.groq.com/docs/models  (e.g. llama-3.1-8b-instant).
GROQ_MODEL=llama-3.3-70b-versatile
